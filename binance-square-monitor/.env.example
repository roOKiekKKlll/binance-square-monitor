# Binance Futures API credentials
# Copy this file to .env and fill in your keys
# Get API keys from: https://www.binance.com/en/my/settings/api-management
# Required permissions: Futures trading (Enable Futures)

# Only trading part need proxy, because the binance required whitelist ip
BINANCE_USE_PROXY=false
# Need add your ip in binance api whitelist
PROXY=ip:port:user:pwd

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
